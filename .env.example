# Pixel Present — environment variables the binary needs.
#
# config.yaml references these as ${VAR} / ${VAR:-default}; the loader expands
# them from the process environment at startup. This file documents the KEYS
# only — never commit real values.
#
# Where the real values live:
#   - Production runtime (systemd): /etc/pixelpresent/pixelpresent.env
#       loaded by the service via EnvironmentFile= (mode 640, root:pixelpresent).
#       Holds the APP runtime values, incl. the app-role DATABASE_DSN.
#   - Production migrations:        /etc/pixelpresent/migrate.env
#       root-only (mode 600). Holds DATABASE_DSN with the OWNER role (DDL),
#       used only by `pixelpresent migrate up` during deploy — never by the
#       running service.
#   - Local dev: not needed. config.yaml's :-defaults point at the podman
#       Postgres and Mailpit from docker-compose.dev.yml.

# --- App ---
APP_ENV=production
APP_BASE_URL=https://pixelpresent.eu
# Listen on loopback only; Caddy is the public entry point (reverse proxy + TLS).
SERVER_ADDR=127.0.0.1:8080

# --- Auth ---
# HMAC secret for signing session cookies. Generate: openssl rand -base64 48
SESSION_SECRET=
# Optional (have sane defaults in config.yaml): 15m / 720h.
MAGIC_LINK_TTL=15m
SESSION_TTL=720h

# --- Logging ---
LOG_LEVEL=info

# --- Database ---
# Postgres over the local unix socket. Runtime uses the least-privilege app role;
# migrations use the owner role (in migrate.env, not here).
#   postgres://pixelpresent_app:<APP_PASSWORD>@/pixelpresent?host=/var/run/postgresql
DATABASE_DSN=

# --- Email (SMTP, Proton in production; Mailpit in dev) ---
# Needed for the magic-link login. Proton: smtp.protonmail.ch:587 (STARTTLS),
# username + SMTP token from the Proton account, over the own domain.
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@pixelpresent.eu
