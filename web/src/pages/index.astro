---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pixel Present">
  <main
    class="mx-auto flex min-h-screen max-w-2xl flex-col items-center justify-center gap-6 px-6 text-center"
  >
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Pixel Present</h1>
    <p class="text-lg text-slate-300">
      Regalos de pixel art que se revelan con una animación.
    </p>
    <p class="text-sm text-slate-500">Landing en construcción (PP-37).</p>
  </main>
</Layout>
